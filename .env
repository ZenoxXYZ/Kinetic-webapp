# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-at-least-32-random-characters
OTP_PEPPER=replace-with-at-least-32-random-characters

# Database
DATABASE_URL=postgresql://kinetic:kinetic@localhost:5432/kinetic_academy?schema=public

# Generic SMS Gateway
# The adapter sends a real HTTP request using this payload template.
# Supported placeholders: {{phone}}, {{message}}, {{otp}}
SMS_USE_MOCK=true
SMS_GATEWAY_URL=
SMS_GATEWAY_AUTH_HEADER=Authorization
SMS_GATEWAY_AUTH_VALUE=
SMS_GATEWAY_PAYLOAD_TEMPLATE={"to":"{{phone}}","message":"{{message}}"}
SMS_OTP_TEMPLATE=Your Kinetic Academy verification code is {{otp}}. It expires in 5 minutes.

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
